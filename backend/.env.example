# Required: Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Required: Voyage AI API key (https://www.voyageai.com) — free 200M tokens/bulan
VOYAGE_API_KEY=pa-...

# Optional: Tavily API key untuk web_search tool (https://tavily.com) — free 1000/bulan.
# Kalau kosong, web_search tool nggak di-register (3 tools lain tetap aktif).
TAVILY_API_KEY=tvly-...

# Optional: Root folder per-user coding workspace (Minggu 8).
# Production di Railway: /data/workspaces (di-mount via Railway volume).
# Local dev: default './tmp/workspaces' (relative ke backend/).
WORKSPACE_ROOT=./tmp/workspaces

# Required: Neon Postgres connection string (pgvector extension auto-available di Neon)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Required: shared secret with FE Next.js. MUST match AUTH_SECRET in frontend .env.local.
# Generate dengan: `openssl rand -hex 32`
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Optional: server config
PORT=8080
ENV=development

# Optional: CORS origins (comma-separated). Default: http://localhost:3000
CORS_ORIGINS=http://localhost:3000
